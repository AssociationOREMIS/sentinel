{
    "name": "oremis/sentinel",
    "description": "OREMIS centralized token validation and ability system (Sentinel)",
    "type": "library",
    "license": "proprietary",
    "autoload": {
        "psr-4": {
            "Oremis\\Sentinel\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Oremis\\Sentinel\\SentinelServiceProvider"
            ],
            "aliases": {
                "TokenAbility": "Oremis\\Sentinel\\Facades\\TokenAbility"
            }
        }
    },
    "require": {
        "php": ">=8.1",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/http": "^10.0|^11.0"
    }
}